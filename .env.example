# Database Connection String
# Replace the value below with your Supabase Connection URI
# Found in Supabase at Project Settings -> Database -> Connection string -> URI
# NOTE: Ensure the URL starts with 'postgresql://' and NOT just 'postgres://'
DATABASE_URL="postgresql://postgres.[your-project-ref]:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres"
